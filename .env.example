# .env.example — Flowlet
# Copy to .env (gitignored). Never commit secrets.

# --- Shared (reused from P1 auth) ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_PORT=3001
# JWT secrets MUST be >= 32 chars (zod-validated at startup). web/ signs, api/ verifies.
JWT_ACCESS_SECRET=change-me-to-a-32+char-random-secret
JWT_REFRESH_SECRET=change-me-to-a-32+char-random-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# --- Database ---
DATABASE_URL=postgresql://flowlet:flowlet@localhost:5432/flowlet

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=flowlet
WORKER_CONCURRENCY=10          # global worker concurrency
PER_USER_CONCURRENCY=3         # fairness cap
AI_QUEUE_CONCURRENCY=5         # separate queue for AI/slow steps
STEP_TIMEOUT_MS=30000

# --- AI step (LLM) ---
LLM_API_KEY=your-llm-provider-key
LLM_MODEL=your-model
LLM_RATE_LIMIT_PER_USER=60     # requests/min, protects shared budget

# --- Connection credential encryption ---
CREDENTIALS_ENC_KEY=32-byte-key-for-at-rest-encryption

# --- Billing (stub) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email ---
EMAIL_FROM=noreply@flowlet.app
EMAIL_PROVIDER_KEY=your-email-provider-key
