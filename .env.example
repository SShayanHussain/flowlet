# .env.example — Flowlet
# Copy to .env (gitignored). Never commit secrets.

# --- Shared (reused from P1 auth) ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_PORT=3001
# Base URL the browser uses to reach the Fastify api. Leave EMPTY in prod/docker
# (nginx serves web + api on one origin). For standalone `npm run dev:web`
# (no nginx), set to the api origin so the browser can reach it (CORS is open):
NEXT_PUBLIC_API_URL=
# Where the browser reaches the Fastify api. Empty = same origin (behind nginx,
# incl. docker compose). For standalone `npm run dev:web` (no nginx), put
# NEXT_PUBLIC_API_URL=http://localhost:3001 in web/.env.local so the builder/runs
# pages can call the api cross-origin (CORS is open).
NEXT_PUBLIC_API_URL=
# JWT secrets MUST be >= 32 chars (zod-validated at startup). web/ signs, api/ verifies.
JWT_ACCESS_SECRET=change-me-to-a-32+char-random-secret
JWT_REFRESH_SECRET=change-me-to-a-32+char-random-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# --- Database ---
DATABASE_URL=postgresql://flowlet:flowlet@localhost:5432/flowlet

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=flowlet
WORKER_CONCURRENCY=10          # global worker concurrency
PER_USER_CONCURRENCY=3         # fairness cap
AI_QUEUE_CONCURRENCY=5         # separate queue for AI/slow steps
STEP_TIMEOUT_MS=30000

# --- AI step (LLM, worker only) ---
# No key → AI steps fail with a config error (never a fake result).
LLM_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-opus-4-8      # env-config so a model retirement is a config change
LLM_MAX_TOKENS=16000
LLM_THINKING=adaptive          # adaptive | off
LLM_RATE_LIMIT_PER_USER=60     # requests/min per workspace, protects shared budget
LLM_INPUT_COST_PER_MTOK=5      # $ per MTok, for per-run cost tracking
LLM_OUTPUT_COST_PER_MTOK=25

# --- Connection credential encryption ---
CREDENTIALS_ENC_KEY=32-byte-key-for-at-rest-encryption

# --- Billing (stub) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email ---
EMAIL_FROM=noreply@flowlet.app
EMAIL_PROVIDER_KEY=your-email-provider-key
